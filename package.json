  "funding": "https://buymeacoffee.com/toakiryu",
  "repository": {
    "type": "git",
    "url": "https://github.com/toaki-cltv/tanstack-head-controller.git"
  },
  "bugs": "https://github.com/toaki-cltv/tanstack-head-controller/issues",
  "keywords": [],
  "scripts": {
    "build": "node ./scripts/build.ts",
    "publish:thc": "pnpm --filter tanstack-head-controller publish --access public",
    "publish:merge": "pnpm --filter thc-plugin-merge publish --access public",
    "publish:ttplate": "pnpm --filter thc-plugin-ttplate publish --access public",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:versions": "node scripts/check-versions.js",
    "sync:versions": "node scripts/sync-versions.js",
    "release": "node scripts/release.js"
  },
  "packageManager": "pnpm@10.31.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.21",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
